<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.FormularioController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <GridPane hgap="10" vgap="10">
        <Label text="Código:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="txtCodigo" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

        <Label text="Nombre:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="txtNombre" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Precio:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="txtPrecio" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

        <Label text="Stock:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="txtStock" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

        <Label text="Categoría:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="txtCategoria" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnGuardar" text="Guardar" style="-fx-base: #28a745; -fx-text-fill: white;"/>
        <Button fx:id="btnCancelar" text="Cancelar" />
    </HBox>
</VBox>