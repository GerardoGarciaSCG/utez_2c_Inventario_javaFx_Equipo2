<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" fx:controller="controlador.MainController">
    <top>
        <VBox spacing="10">
            <padding>
                <Insets top="15" right="15" bottom="10" left="15"/>
            </padding>
            <Label text="Gestión de Inventario" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="Buscar: "/>
                <TextField fx:id="txtBuscar" promptText="Por nombre o código..." prefWidth="300"/>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnNuevo" text="Nuevo Producto" style="-fx-base: #28a745; -fx-text-fill: white;"/>
            </HBox>
        </VBox>
    </top>
    <center>
        <TableView fx:id="tablaProductos">
            <columns>
                <TableColumn fx:id="colCodigo" text="Código" prefWidth="100"/>
                <TableColumn fx:id="colNombre" text="Nombre" prefWidth="200"/>
                <TableColumn fx:id="colPrecio" text="Precio" prefWidth="80"/>
                <TableColumn fx:id="colStock" text="Stock" prefWidth="80"/>
                <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="150"/>
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </center>
    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <padding>
                <Insets top="10" right="15" bottom="10" left="15"/>
            </padding>
            <Button fx:id="btnEditar" text="Editar Seleccionado" />
            <Button fx:id="btnEliminar" text="Eliminar" style="-fx-base: #dc3545; -fx-text-fill: white;"/>
        </HBox>
    </bottom>
</BorderPane>