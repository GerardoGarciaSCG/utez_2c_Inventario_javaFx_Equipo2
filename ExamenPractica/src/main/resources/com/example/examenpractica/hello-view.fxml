<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ListView?>
<VBox spacing="10" alignment="CENTER" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.examenpractica.controllers.controller">

    <TextField fx:id="txtNombre"/>
    <TextField fx:id="txtTelefono"/>
    <ComboBox fx:id="cmbParentesco"/>

    <HBox spacing="10">
        <Button text="Agregar" onAction="#agregar"/>
        <Button text="Buscar" onAction="#buscar"/>
        <Button text="Actualizar" onAction="#actualizar"/>
        <Button text="Eliminar" onAction="#eliminar"/>
        <Button text="Limpiar" onAction="#limpiar"/>
    </HBox>

    <ListView fx:id="listView"/>
    <Label fx:id="lblMensaje"/>

</VBox>
